@startuml CU13_Consultar_Estudiante
autonumber
actor "Usuario Autorizado" as Actor
participant "App Web" as UI
participant "EstudianteController" as Ctrl
participant "EstudianteService" as Serv
database "BaseDatos" as DB

Actor -> UI: Ingresa código o DNI del estudiante y busca
UI -> Ctrl: buscarEstudiante(criterio)
Ctrl -> Serv: obtenerDetalleEstudiante(criterio)
activate Serv
Serv -> DB: SELECT * FROM estudiantes WHERE codigo = criterio OR dni = criterio
DB --> Serv: datos_estudiante
Ctrl <-- Serv: datos_estudiante
deactivate Serv
UI <-- Ctrl: renderizarDetalleEstudiante(datos)
Actor <-- UI: Muestra el perfil y estado completo del estudiante
@enduml