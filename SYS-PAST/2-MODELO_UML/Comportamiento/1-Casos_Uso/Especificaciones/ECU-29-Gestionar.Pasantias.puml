@startuml Diagrama_Detalle_CU28
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle

' --- ETIQUETA IZQUIERDA ---
card "CU28" as CU28

' --- TABLA PRINCIPAL DE ESPECIFICACIÓN (Formato HTML integrado) ---
rectangle TablaCU28 [
<table border="1" cellspacing="0" cellpadding="5" bgcolor="white">
<tr><td><b>Caso de uso</b></td><td>Cerrar proceso</td></tr>
<tr><td><b>Id</b></td><td>CU-28</td></tr>
<tr><td><b>Breve descripción</b></td><td>Permite dar por concluido de manera definitiva el ciclo de la pasantía de un estudiante.</td></tr>
<tr><td><b>Actores primarios</b></td><td> </td></tr>
<tr><td><b>Actores secundarios</b></td><td> </td></tr>
<tr><td><b>Precondiciones</b></td><td> </td></tr>
<tr><td><b>Flujo principal</b></td><td> </td></tr>
<tr><td><b>Postcondiciones</b></td><td> </td></tr>
</table>
]

' --- ELEMENTOS DE LA DERECHA (CONECTADOS DESDE LAS CELDAS) ---

' Actores
rectangle "Director" as ActDirector
rectangle "Base de Datos" as ActBD

' Precondición
rectangle "La constancia debió ser emitida y todos los documentos archivados." as Precondicion

' Lista del Flujo Principal
rectangle FlujoPasos [
<table border="1" cellspacing="0" cellpadding="4" bgcolor="white">
<tr><td><b>1</b></td><td>El director busca el expediente del estudiante en fase final.</td></tr>
<tr><td><b>2</b></td><td>El sistema muestra un checklist con todas las fases completas.</td></tr>
<tr><td><b>3</b></td><td>El director presiona 'Cerrar Proceso'.</td></tr>
<tr><td><b>4</b></td><td>El sistema cambia el estado del expediente a 'Archivado / Concluido'.</td></tr>
</table>
]

' Postcondición
rectangle "El expediente pasa al archivo histórico del sistema, liberando al alumno del proceso activo." as Postcondicion


' --- CONEXIONES CON REGLAS DE DIRECCIÓN ---
CU28 .--> TablaCU28

TablaCU28 .--> ActDirector
TablaCU28 .--> ActBD
TablaCU28 .--> Precondicion
TablaCU28 .--> FlujoPasos
TablaCU28 .--> Postcondicion

@enduml