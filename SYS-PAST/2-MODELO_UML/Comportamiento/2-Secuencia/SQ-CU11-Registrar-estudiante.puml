@startuml CU11_Registrar_Estudiante
autonumber
actor "Director / Secretaria" as Actor
participant "App Web" as UI
participant "EstudianteController" as Ctrl
participant "EstudianteService" as Serv
database "BaseDatos" as DB

Actor -> UI: Ingresa datos del nuevo estudiante (código, DNI, nombres)
UI -> Ctrl: registrarEstudiante(datosEstudiante)
Ctrl -> Serv: matricularEstudiante(datosEstudiante)
activate Serv
Serv -> DB: INSERT INTO estudiantes(...)
DB --> Serv: estudiante_registrado
Ctrl <-- Serv: exitoRegistro
deactivate Serv
UI <-- Ctrl: limpiarFormulario()
Actor <-- UI: Muestra "Estudiante registrado correctamente"
@enduml