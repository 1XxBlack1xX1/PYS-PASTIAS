@startuml Patron_Singleton_Conexion

class BaseDatosConexion {
    - static BaseDatosConexion instancia
    - String cadenaConexion
    - boolean conectado
    
    - BaseDatosConexion()
    + static BaseDatosConexion getInstancia()
    + void ejecutarQuery(String sql)
    + void desconectar()
}

note right of BaseDatosConexion::getInstancia
  if (instancia == null) {
      instancia = new BaseDatosConexion()
  }
  return instancia
end note

@enduml